# Скопируй этот файл в .env и заполни значения.
# cp .env.example .env

# База данных SQLite (Prisma)
DATABASE_URL="file:./dev.db"

# OpenAI — нужен для умного переводчика и AI-воркбука.
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Модель для умных функций
OPENAI_MODEL="gpt-4o-mini"

# Web Push — сгенерируй пару: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
# Случайная строка для защиты cron-эндпоинта рассылки пушей (обязательно на проде)
CRON_SECRET=""

# Часовой пояс пользователя для границы «дня» серии/цели (в часах от UTC).
# Нужно на облачном сервере (там время UTC). Напр. Алматы = 5. Пусто = время сервера.
APP_TZ_OFFSET=""
