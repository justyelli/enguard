// Enguard — схема БД (SQLite). Один пользователь, без аутентификации.
// Документация: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────── Книги и чтение ───────────────────────────

model Book {
  id        Int       @id @default(autoincrement())
  title     String
  author    String?
  language  String    @default("en")
  createdAt DateTime  @default(now())

  chapters  Chapter[]
  progress  ReadingProgress?
  lookups   WordLookup[]
}

model Chapter {
  id      Int    @id @default(autoincrement())
  bookId  Int
  index   Int    // порядковый номер главы (с 0)
  title   String?
  content String // полный текст главы

  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, index])
}

model ReadingProgress {
  id           Int      @id @default(autoincrement())
  bookId       Int      @unique
  chapterIndex Int      @default(0)
  scrollPct    Float    @default(0) // 0..1 прокрутка внутри главы
  updatedAt    DateTime @updatedAt

  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// Каждый клик по слову в ридере — основа ежедневной аналитики.
model WordLookup {
  id        Int      @id @default(autoincrement())
  word      String   // слово в нижнем регистре
  context   String?  // предложение, в котором встретилось слово
  bookId    Int?
  createdAt DateTime @default(now())

  book      Book?    @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([word])
  @@index([createdAt])
}

// Кэш умных переводов, чтобы не дёргать OpenAI повторно.
model Translation {
  id        Int      @id @default(autoincrement())
  term      String   @unique // запрашиваемое слово/фраза (lower, trimmed)
  payload   String   // JSON: { translation, examples[], differences[], synonyms[], ... }
  createdAt DateTime @default(now())
}

// ─────────────────────────── Коллекции и карточки ───────────────────────────

model Collection {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())

  cards       Card[]
}

model Card {
  id            Int       @id @default(autoincrement())
  collectionId  Int
  word          String    // английское слово/фраза
  translation   String    // перевод
  example       String?   // пример употребления
  context       String?   // предложение-источник (если добавлено из книги)
  starred       Boolean   @default(false) // избранное

  // SRS (алгоритм типа SM-2)
  ease          Float     @default(2.5)
  intervalDays  Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  dueDate       DateTime  @default(now())
  lastReviewed  DateTime?

  createdAt     DateTime  @default(now())

  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  reviews       ReviewLog[]

  @@index([dueDate])
}

model ReviewLog {
  id        Int      @id @default(autoincrement())
  cardId    Int
  mode      String   // flashcard | choose | reverse | type | listen | match | context | sprint
  correct   Boolean
  createdAt DateTime @default(now())

  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// ─────────────────────────── Воркбук ───────────────────────────

model Workbook {
  id        Int      @id @default(autoincrement())
  day       String   @unique // YYYY-MM-DD
  title     String
  tasks     String   // JSON: массив заданий
  answers    String  // JSON: правильные ответы
  completed  Boolean @default(false)
  rewardedXp Boolean @default(false) // XP за выполнение выдаётся один раз
  createdAt  DateTime @default(now())
}

// ─────────────────────────── Практика (4 навыка) ───────────────────────────

// Лог любой практики (speaking / listening / grammar) для статистики.
model PracticeLog {
  id        Int      @id @default(autoincrement())
  skill     String   // speaking | listening | grammar | writing
  detail    String?  // тема/режим
  score     Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([skill])
}

// Профиль игрока (singleton) — XP, уровень, серия, валюта, бусты.
model Profile {
  id             Int       @id @default(autoincrement())
  totalXp        Int       @default(0)
  todayXp        Int       @default(0)
  todayDay       String? // YYYY-MM-DD, к которому относится todayXp
  dailyGoalXp    Int       @default(50)
  goalRewardedDay String? // день, за который уже выдана награда за цель

  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDay  String? // YYYY-MM-DD последнего активного дня

  gems           Int       @default(0)
  freezes        Int       @default(0) // заморозки серии (макс 2)
  boost2         Int       @default(0) // жетоны ускорения 2x
  boost3         Int       @default(0) // жетоны ускорения 3x

  boostMult      Int       @default(1) // активный множитель: 1 / 2 / 3
  boostExpires   DateTime?

  updatedAt      DateTime  @updatedAt
}

// Письменные работы с разбором от AI.
model WritingSubmission {
  id        Int      @id @default(autoincrement())
  prompt    String
  text      String
  score     Int      @default(0)
  feedback  String   // JSON: { corrections:[{original,fixed,explanation}], improved, comment }
  createdAt DateTime @default(now())

  @@index([createdAt])
}
